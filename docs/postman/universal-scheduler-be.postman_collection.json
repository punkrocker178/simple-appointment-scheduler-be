    {
      "name": "Availability",
      "description": "AvailabilityController — any authenticated user; date must be yyyy-MM-dd",
      "item": [
        {
          "name": "Check Availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/availability?dealershipId={{dealershipId}}&serviceTypeId={{serviceTypeId}}&date={{bookingDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "availability"],
              "query": [
                { "key": "dealershipId", "value": "{{dealershipId}}" },
                { "key": "serviceTypeId", "value": "{{serviceTypeId}}" },
                { "key": "date", "value": "{{bookingDate}}", "description": "Format: yyyy-MM-dd (e.g. 2026-06-17)" }
              ]
            },
            "description": "Returns available time slots for a service type on a given date."
          },
          "response": []
        }
      ]
    },
