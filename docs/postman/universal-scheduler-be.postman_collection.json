{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Universal Scheduler BE",
    "description": "API collection for the Universal Appointment Scheduler backend.\n\nDerived from controller tests in `universal-scheduler-be.Tests/Controllers/` and `universal-scheduler-be.http`.\n\n## Setup\n1. Run the API: `dotnet run` (default HTTP: http://localhost:5210)\n2. Set `AdminSeed:Password` in User Secrets for admin login\n3. Run **Auth → Login (Admin)** — the test script saves `token` automatically\n4. Replace collection variables with real IDs from create responses as needed\n\n## Permissions\n- Admin: dealerships, skills, service types, bays, technicians\n- Admin/Staff: customers, vehicles, appointments (read all)\n- User: appointments:read:own, appointments:write, /api/me/*",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5210" },
    { "key": "token", "value": "" },
    { "key": "dealershipId", "value": "c3000001-0000-4000-8000-000000000001" },
    { "key": "skillId", "value": "d4000001-0000-4000-8000-000000000001" },
    { "key": "serviceTypeId", "value": "c9000001-0000-4000-8000-000000000001" },
    { "key": "serviceBayId", "value": "f6000001-0000-4000-8000-000000000001" },
    { "key": "technicianId", "value": "f7000001-0000-4000-8000-000000000001" },
    { "key": "customerId", "value": "a7000001-0000-4000-8000-000000000001" },
    { "key": "vehicleId", "value": "b8000001-0000-4000-8000-000000000001" },
    { "key": "appointmentId", "value": "a1000001-0000-4000-8000-000000000099" },
    { "key": "bookingDate", "value": "2026-06-17" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "AuthController — register, login, current user profile",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Open registration — always assigns User role. Returns 201 Created or 409 Conflict if email exists."
          },
          "response": []
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.test('Token saved to collection variable', () => {",
                  "        pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@localhost\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Admin login. Set AdminSeed:Password in User Secrets. Test script saves JWT to `token` variable."
          },
          "response": []
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Returns UserId, Email, Role, CustomerId, Permissions from JWT claims."
          },
          "response": []
        }
      ]
    },
