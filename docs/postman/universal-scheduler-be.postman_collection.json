              "path": ["api", "dealerships", "{{dealershipId}}", "appointments"],
              "query": [
                { "key": "date", "value": "{{bookingDate}}", "description": "Format: yyyy-MM-dd" }
              ]
            },
            "description": "Requires appointments:read. Returns 400 Bad Request for invalid date format."
          },
          "response": []
        }
